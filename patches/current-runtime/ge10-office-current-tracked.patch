+    WCHAR *copy;
+
+    FIXME("iface %p, name %s, type %#x, value %s stub.\n", iface, debugstr_w(name), type, debugstr_w(value));
+
+    if (!lstrcmpW(name, L"d") || !lstrcmpW(name, L"viewBox"))
+    {
+        if (!(copy = d2d_strdupW(value)))
+            return E_OUTOFMEMORY;
+        if (!lstrcmpW(name, L"d"))
+        {
+            free(element->path_data);
+            element->path_data = copy;
+        }
+        else
+        {
+            free(element->viewbox_data);
+            element->viewbox_data = copy;
+        }
+    }
+    return S_OK;
+}
