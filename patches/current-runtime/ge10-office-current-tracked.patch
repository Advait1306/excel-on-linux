+    if (IsEqualGUID(iid, &IID_IUnknown) || IsEqualGUID(iid, &IID_ID2D1Resource)
+            || IsEqualGUID(iid, &IID_ID2D1SvgAttribute_WINE))
+    {
+        d2d_svg_attribute_AddRef(iface);
+        *out = iface;
+        return S_OK;
+    }
