+    struct d2d_svg_element *element = impl_from_ID2D1SvgElement(iface);
+
+    FIXME("iface %p, name %s, type %#x, value %p, value_size %u stub.\n", iface, debugstr_w(name), type, value,
+            value_size);
+
+    if (!lstrcmpW(name, L"fill") && type == 1 && value_size >= sizeof(D2D1_COLOR_F))
+    {
+        element->fill = *(const D2D1_COLOR_F *)value;
+        element->has_fill = TRUE;
+        TRACE("SVG fill for %s is {%.8e, %.8e, %.8e, %.8e}.\n", debugstr_w(element->tag_name),
+                element->fill.r, element->fill.g, element->fill.b, element->fill.a);
+    }
+    else if (!lstrcmpW(name, L"fill-opacity") && type == 0 && value_size >= sizeof(float))
+    {
+        element->fill_opacity = *(const float *)value;
+    }
+    else if ((!lstrcmpW(name, L"fill-rule") || !lstrcmpW(name, L"clip-rule")) && type == 2 && value_size >= sizeof(UINT32))
+    {
+        element->fill_mode = *(const UINT32 *)value ? D2D1_FILL_MODE_WINDING : D2D1_FILL_MODE_ALTERNATE;
+    }
+    return S_OK;
+}
