+static HRESULT STDMETHODCALLTYPE d2d_svg_element_GetAttributeValuePod(void *iface, const WCHAR *name, UINT32 type,
+        void *value, UINT32 value_size)
+{
+    struct d2d_svg_element *element = impl_from_ID2D1SvgElement(iface);
+
+    FIXME("iface %p, name %s, type %#x, value %p, value_size %u semi-stub.\n", iface, debugstr_w(name), type, value,
+            value_size);
+
+    if (!value && value_size)
+        return E_INVALIDARG;
+
+    if (value)
+        memset(value, 0, value_size);
+
+    switch (type)
+    {
+        case 0: /* D2D1_SVG_ATTRIBUTE_POD_TYPE_FLOAT */
+            if (value_size < sizeof(float))
+                return D2DERR_INSUFFICIENT_BUFFER;
+            *(float *)value = 0.0f;
+            return S_OK;
+
+        case 11: /* D2D1_SVG_ATTRIBUTE_POD_TYPE_PRESERVE_ASPECT_RATIO */
+            if (value_size < 12)
+                return D2DERR_INSUFFICIENT_BUFFER;
+            ((UINT32 *)value)[0] = FALSE;
+            ((UINT32 *)value)[1] = 5; /* D2D1_SVG_ASPECT_ALIGN_X_MID_Y_MID */
+            ((UINT32 *)value)[2] = 0; /* D2D1_SVG_ASPECT_SCALING_MEET */
+            return S_OK;
+
+        case 12: /* D2D1_SVG_ATTRIBUTE_POD_TYPE_VIEWBOX */
+            if (value_size < 4 * sizeof(float))
+                return D2DERR_INSUFFICIENT_BUFFER;
+            ((float *)value)[0] = 0.0f;
+            ((float *)value)[1] = 0.0f;
+            ((float *)value)[2] = element->document->viewport_size.width;
+            ((float *)value)[3] = element->document->viewport_size.height;
+            return S_OK;
+
+        case 13: /* D2D1_SVG_ATTRIBUTE_POD_TYPE_LENGTH */
+            if (value_size < sizeof(float) + sizeof(UINT32))
+                return D2DERR_INSUFFICIENT_BUFFER;
+            ((float *)value)[0] = !lstrcmpW(name, L"height") ? element->document->viewport_size.height
+                    : element->document->viewport_size.width;
+            ((UINT32 *)value)[1] = 0; /* D2D1_SVG_LENGTH_UNITS_NUMBER */
+            return S_OK;
+
+        default:
+            return D2DERR_INVALID_CALL;
+    }
+}
