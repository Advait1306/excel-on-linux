+static void d2d_svg_element_detach(struct d2d_svg_element *element)
+{
+    if (!element->parent)
+        return;
+
+    if (element->prev_sibling)
+        element->prev_sibling->next_sibling = element->next_sibling;
+    else
+        element->parent->first_child = element->next_sibling;
+
+    if (element->next_sibling)
+        element->next_sibling->prev_sibling = element->prev_sibling;
+    else
+        element->parent->last_child = element->prev_sibling;
+
+    element->parent = NULL;
+    element->prev_sibling = NULL;
+    element->next_sibling = NULL;
+}
+
+static void d2d_svg_element_link_child(struct d2d_svg_element *parent, struct d2d_svg_element *child)
+{
+    d2d_svg_element_detach(child);
+
+    child->parent = parent;
+    child->prev_sibling = parent->last_child;
+    child->next_sibling = NULL;
+    if (parent->last_child)
+        parent->last_child->next_sibling = child;
+    else
+        parent->first_child = child;
+    parent->last_child = child;
+    d2d_svg_element_AddRef(&child->iface);
+}
