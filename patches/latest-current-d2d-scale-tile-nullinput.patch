+static WCHAR *d2d_strdupW(const WCHAR *str)
+{
+    WCHAR *ret;
+    size_t len;
+
+    if (!str)
+        return NULL;
+
+    len = lstrlenW(str) + 1;
+    if ((ret = malloc(len * sizeof(*ret))))
+        memcpy(ret, str, len * sizeof(*ret));
+    return ret;
+}
