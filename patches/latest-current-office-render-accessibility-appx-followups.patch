+static DWORD appcontainer_name_hash(PCWSTR name, UINT index)
+{
+    DWORD hash = 2166136261u ^ index;
+
+    while (*name)
+    {
+        WCHAR ch = *name++;
+
+        if (ch >= 'A' && ch <= 'Z')
+            ch += 'a' - 'A';
+        hash ^= ch;
+        hash *= 16777619u;
+        hash = (hash << 5) | (hash >> 27);
+    }
+    return hash ? hash : index + 1;
+}
+
+HRESULT WINAPI DeriveAppContainerSidFromAppContainerName(PCWSTR container_name, PSID *container_sid)
+{
+    SID_IDENTIFIER_AUTHORITY authority = { SECURITY_APP_PACKAGE_AUTHORITY };
+    DWORD rid[7];
+    UINT i;
+
+    FIXME("(%s, %p): semi-stub\n", debugstr_w(container_name), container_sid);
+
+    if (!container_name || !container_sid)
+        return E_INVALIDARG;
+
+    for (i = 0; i < ARRAY_SIZE(rid); ++i)
+        rid[i] = appcontainer_name_hash(container_name, i);
+
+    if (!AllocateAndInitializeSid(&authority, SECURITY_APP_PACKAGE_RID_COUNT,
+            SECURITY_APP_PACKAGE_BASE_RID, rid[0], rid[1], rid[2], rid[3], rid[4], rid[5], rid[6],
+            container_sid))
+        return HRESULT_FROM_WIN32(GetLastError());
+
+    return S_OK;
+}
+
+HRESULT WINAPI GetAppContainerFolderPath(PCWSTR container_sid, PWSTR *path)
+{
+    static const WCHAR packagesW[] = L"\\Packages\\";
+    static const WCHAR acW[] = L"\\AC";
+    WCHAR local_appdata[MAX_PATH];
+    SIZE_T len;
+    PWSTR ret;
+
+    FIXME("(%s, %p): semi-stub\n", debugstr_w(container_sid), path);
+
+    if (!container_sid || !path)
+        return E_INVALIDARG;
+
+    if (!GetEnvironmentVariableW(L"LOCALAPPDATA", local_appdata, ARRAY_SIZE(local_appdata)))
+        lstrcpyW(local_appdata, L"C:\\users\\Public\\AppData\\Local");
+
+    len = lstrlenW(local_appdata) + ARRAY_SIZE(packagesW) - 1 + lstrlenW(container_sid) + ARRAY_SIZE(acW);
+    if (!(ret = CoTaskMemAlloc(len * sizeof(WCHAR))))
+        return E_OUTOFMEMORY;
+
+    lstrcpyW(ret, local_appdata);
+    lstrcatW(ret, packagesW);
+    lstrcatW(ret, container_sid);
+    lstrcatW(ret, acW);
+    *path = ret;
+    return S_OK;
+}
