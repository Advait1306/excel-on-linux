+        entry = LocalAlloc(LPTR, 16 * sizeof(*entry));
+        if (!entry)
+            return E_OUTOFMEMORY;
+
+        entry[0].eStatus = SL_LICENSING_STATUS_UNLICENSED;
+        entry[0].hrReason = OFFICE_E_LICENSE_NOT_INSTALLED;
+        *count = 16;
+        *status = entry;
+        FIXME("returning native OSPP-compatible unlicensed status list.\n");
+        return S_OK;
+    }
+
+    entry = LocalAlloc(LPTR, sizeof(*entry));
+    if (!entry)
+        return E_OUTOFMEMORY;
+
+    if (product)
+        entry->SkuId = *product;
+    else if (app)
+        entry->SkuId = *app;
+    else if (has_consumed_right)
+        entry->SkuId = last_consumed_right;
+    else
+    {
+        LocalFree(entry);
+        return SL_E_RIGHT_NOT_CONSUMED;
+    }
+    if (GetEnvironmentVariableW(L"OFFICE_SPP_LICENSED_STATUS", env, ARRAY_SIZE(env)))
+    {
+        entry->eStatus = SL_LICENSING_STATUS_LICENSED;
+        entry->dwGraceTime = 0;
+        entry->dwTotalGraceDays = 0;
+        FIXME("returning diagnostic licensed status.\n");
+    }
+    else
+    {
+        entry->eStatus = SL_LICENSING_STATUS_IN_GRACE_PERIOD;
+        entry->dwGraceTime = 30 * 24 * 60;
+        entry->dwTotalGraceDays = 30;
+    }
+    entry->hrReason = S_OK;
+
+    *count = 1;
+    *status = entry;
+    return S_OK;
+}
