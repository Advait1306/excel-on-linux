+}
+
+HRESULT WINAPI SLSetAuthenticationData(HSLC handle, UINT size, const BYTE *data)
+{
+    char bytes[3 * 32 + 1];
+    UINT i, j, limit;
+
+    FIXME("(%p %u %p) stub\n", handle, size, data);
+
+    if (!handle || (size && !data))
+        return E_INVALIDARG;
+
+    for (i = 0; i < size; i += 32)
+    {
+        limit = min(size - i, 32);
+        for (j = 0; j < limit; ++j)
+            sprintf(bytes + 3 * j, "%02x ", data[i + j]);
+        bytes[3 * limit] = 0;
+        FIXME("authentication data +0x%04x: %s\n", i, bytes);
+    }
+
+    LocalFree(last_authentication_data);
+    last_authentication_data = NULL;
+    last_authentication_data_size = 0;
+
+    if (size)
+    {
+        last_authentication_data = LocalAlloc(0, size);
+        if (!last_authentication_data)
+            return E_OUTOFMEMORY;
+        memcpy(last_authentication_data, data, size);
+        last_authentication_data_size = size;
+    }
+
+    return S_OK;
+}
+
+HRESULT WINAPI SLGetAuthenticationResult(HSLC handle, UINT *size, BYTE **data)
+{
+    WCHAR env[4];
+
+    FIXME("(%p %p %p) stub\n", handle, size, data);
+
+    if (!handle || !size || !data)
+        return E_INVALIDARG;
+
+    if (GetEnvironmentVariableW(L"OFFICE_SPP_AUTH_FLAGS_RESULT", env, ARRAY_SIZE(env)))
+    {
+        *data = LocalAlloc(0, sizeof(office_subscription_validator_result));
+        if (!*data)
+            return E_OUTOFMEMORY;
+        memcpy(*data, office_subscription_validator_result, sizeof(office_subscription_validator_result));
+        *size = sizeof(office_subscription_validator_result);
+        FIXME("returning Office subscription external-validator auth result.\n");
+        return S_OK;
+    }
+
+    if (!last_authentication_data_size)
+    {
+        *size = 0;
+        *data = NULL;
+        return SL_E_AUTHN_CHALLENGE_NOT_SET;
+    }
+
+    *data = LocalAlloc(0, last_authentication_data_size);
+    if (!*data)
+        return E_OUTOFMEMORY;
+
+    memcpy(*data, last_authentication_data, last_authentication_data_size);
+    *size = last_authentication_data_size;
+    return S_OK;
+}
+
+HRESULT WINAPI SLConsumeRight(HSLC handle, const SLID *app, const SLID *product,
+                              const WCHAR *right_name, void *reserved)
+{
+    FIXME("(%p %s %s %s %p) stub\n", handle, wine_dbgstr_guid(app),
+          wine_dbgstr_guid(product), debugstr_w(right_name), reserved);
+
+    if (!handle || !app || reserved)
+        return E_INVALIDARG;
+
+    last_consumed_right = product ? *product : *app;
+    has_consumed_right = TRUE;
+    return S_OK;
+}
+
+HRESULT WINAPI SLGetPolicyInformation(HSLC handle, const WCHAR *name, SLDATATYPE *type,
+                                      UINT *size, BYTE **data)
+{
+    DWORD value;
+    const WCHAR *string_value;
+    WCHAR env[4];
+
+    FIXME("(%p %s %p %p %p) stub\n", handle, debugstr_w(name), type, size, data);
+
+    if (!handle || !name || !size || !data)
+        return E_INVALIDARG;
+
+    if (!wcscmp(name, L"*"))
+        return return_policy_name_list(type, size, data);
+
+    if (!wcsncmp(name, L"office-", lstrlenW(L"office-")) &&
+        GetEnvironmentVariableW(L"OFFICE_SPP_EMPTY_OFFICE_POLICIES", env, ARRAY_SIZE(env)))
+    {
+        FIXME("returning diagnostic empty string for Office policy %s.\n", debugstr_w(name));
+        return return_string_policy(type, size, data, L"");
+    }
+
+    if (get_known_office_dword_policy(name, &value))
+        return return_dword_policy(type, size, data, value);
+
+    if (get_known_office_string_policy(name, &string_value))
+        return return_string_policy(type, size, data, string_value);
+
+    if (type)
+        *type = SL_DATA_NONE;
+    *size = 0;
+    *data = NULL;
+    return SL_E_VALUE_NOT_FOUND;
+}
+
+HRESULT WINAPI SLGetPolicyInformationDWORD(HSLC handle, const WCHAR *name, DWORD *value)
+{
+    FIXME("(%p %s %p) stub\n", handle, debugstr_w(name), value);
+
+    if (!handle || !name || !value)
+        return E_INVALIDARG;
+
+    *value = 0;
+    if (get_known_office_dword_policy(name, value))
+        return S_OK;
+
+    return SL_E_VALUE_NOT_FOUND;
+}
+
+HRESULT WINAPI SLLoadApplicationPolicies(const SLID *app, const SLID *product, DWORD flags, HSLP *context)
+{
+    FIXME("(%s %s %lx %p) stub\n", wine_dbgstr_guid(app), wine_dbgstr_guid(product), flags, context);
+
+    if (!app || !context)
+        return E_INVALIDARG;
+
+    *context = (HSLP)0xdeadbee1;
+    return S_OK;
+}
+
+HRESULT WINAPI SLGetApplicationPolicy(HSLP context, const WCHAR *name, SLDATATYPE *type,
+                                      UINT *size, BYTE **data)
+{
+    DWORD value;
+    const WCHAR *string_value;
+    WCHAR env[4];
+
+    FIXME("(%p %s %p %p %p) stub\n", context, debugstr_w(name), type, size, data);
+
+    if (!context || !name || !size || !data)
+        return E_INVALIDARG;
+
+    if (!wcscmp(name, L"*"))
+        return return_policy_name_list(type, size, data);
+
+    if (!wcsncmp(name, L"office-", lstrlenW(L"office-")) &&
+        GetEnvironmentVariableW(L"OFFICE_SPP_EMPTY_OFFICE_POLICIES", env, ARRAY_SIZE(env)))
+    {
+        FIXME("returning diagnostic empty string for Office application policy %s.\n", debugstr_w(name));
+        return return_string_policy(type, size, data, L"");
+    }
+
+    if (get_known_office_dword_policy(name, &value))
+        return return_dword_policy(type, size, data, value);
+
+    if (get_known_office_string_policy(name, &string_value))
+        return return_string_policy(type, size, data, string_value);
+
+    if (type)
+        *type = SL_DATA_NONE;
+    *size = 0;
+    *data = NULL;
+    return SL_E_VALUE_NOT_FOUND;
+}
+
+HRESULT WINAPI SLUnloadApplicationPolicies(HSLP context, DWORD flags)
+{
+    FIXME("(%p %lx) stub\n", context, flags);
+
+    if (!context)
+        return E_INVALIDARG;
+
+    return S_OK;
 }
 
