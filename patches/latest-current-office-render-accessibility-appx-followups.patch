+    L"office-AppPrivilege.licensing_runOnNonCloud",
+};
+
+static HRESULT return_policy_name_list(SLDATATYPE *type, UINT *size, BYTE **data)
+{
+    WCHAR *multi, *cursor;
+    SIZE_T len = 1;
+    unsigned int i;
+
+    for (i = 0; i < ARRAY_SIZE(office_policy_names); ++i)
+        len += wcslen(office_policy_names[i]) + 1;
+
+    multi = LocalAlloc(LPTR, len * sizeof(WCHAR));
+    if (!multi)
+        return E_OUTOFMEMORY;
+
+    cursor = multi;
+    for (i = 0; i < ARRAY_SIZE(office_policy_names); ++i)
+    {
+        lstrcpyW(cursor, office_policy_names[i]);
+        cursor += lstrlenW(cursor) + 1;
+    }
+
+    if (type)
+        *type = SL_DATA_MULTI_SZ;
+    *size = len * sizeof(WCHAR);
+    *data = (BYTE *)multi;
+    return S_OK;
+}
+
+static HRESULT return_string_policy(SLDATATYPE *type, UINT *size, BYTE **data, const WCHAR *value)
+{
+    WCHAR *policy;
+    SIZE_T bytes = (lstrlenW(value) + 1) * sizeof(WCHAR);
+
+    policy = LocalAlloc(0, bytes);
+    if (!policy)
+        return E_OUTOFMEMORY;
+
+    memcpy(policy, value, bytes);
+    if (type)
+        *type = SL_DATA_SZ;
+    *size = bytes;
+    *data = (BYTE *)policy;
+    return S_OK;
+}
+
+static HRESULT return_dword_policy(SLDATATYPE *type, UINT *size, BYTE **data, DWORD value)
+{
+    DWORD *policy;
+
+    policy = LocalAlloc(0, sizeof(*policy));
+    if (!policy)
+        return E_OUTOFMEMORY;
+
+    *policy = value;
+    if (type)
+        *type = SL_DATA_DWORD;
+    *size = sizeof(*policy);
+    *data = (BYTE *)policy;
+    return S_OK;
+}
+
+static BOOL get_known_office_string_policy(const WCHAR *name, const WCHAR **value)
+{
+    if (!wcscmp(name, L"office-LicenseType"))
+    {
+        *value = L"Subscription";
+        return TRUE;
+    }
+    if (!wcscmp(name, L"office-ApplicationBitmap"))
+    {
+        *value = L"0x000001BB";
+        return TRUE;
+    }
+    return FALSE;
+}
+
+static BOOL get_known_office_dword_policy(const WCHAR *name, DWORD *value)
+{
+    if (!wcscmp(name, L"office-C845E028-E091-442E-8202-21F596C559A0"))
+    {
+        *value = 1;
+        return TRUE;
+    }
+    if (!wcscmp(name, L"office-ParentCode"))
+    {
+        *value = 7;
+        return TRUE;
+    }
+    if (!wcscmp(name, L"office-AppPrivilege.ProXML") ||
+        !wcscmp(name, L"office-AppPrivilege.CommercialUse") ||
+        !wcscmp(name, L"office-AppPrivilege.OPEP") ||
+        !wcscmp(name, L"office-Activatable") ||
+        !wcscmp(name, L"office-DisplayEULA") ||
+        !wcscmp(name, L"office-AppPrivilege.OneNotePro") ||
+        !wcscmp(name, L"office-AppPrivilege.licensing_unknownEnabled") ||
+        !wcscmp(name, L"office-AppPrivilege.licensing_isPaid") ||
+        !wcscmp(name, L"office-AppPrivilege.licensing_isSubscription") ||
+        !wcscmp(name, L"office-AppPrivilege.cxe_whatsnewdialog") ||
+        !wcscmp(name, L"office-AppPrivilege.otel_featureGateSubscriptionAudience") ||
+        !wcscmp(name, L"office-AppPrivilege.gfx_donateToScience") ||
+        !wcscmp(name, L"office-AppPrivilege.licensing_runOnNonCloud"))
+    {
+        *value = 1;
+        return TRUE;
+    }
+    if (!wcscmp(name, L"office-EulaID"))
+    {
+        *value = 18;
+        return TRUE;
+    }
+    if (!wcscmp(name, L"office-DisallowPhone"))
+    {
+        *value = 1;
+        return TRUE;
+    }
+    if (!wcscmp(name, L"office-MPC"))
+    {
+        *value = 2244;
+        return TRUE;
+    }
+    if (!wcscmp(name, L"Security-SPP-CMIDExpirationPeriod") ||
+        !wcscmp(name, L"Security-Licensing-SLC-CMIDExpirationPeriod"))
+    {
+        *value = 43200;
+        return TRUE;
+    }
+    if (!wcscmp(name, L"Security-SPP-Reserved-EnableNotificationMode") ||
+        !wcscmp(name, L"Security-SPP-ActivationResetCount"))
+    {
+        *value = 1;
+        return TRUE;
+    }
+    if (!wcscmp(name, L"Security-SPP-ActivationResetCountMax"))
+    {
+        *value = 0x7fffffff;
+        return TRUE;
+    }
+    if (!wcsncmp(name, L"office-AppPrivilege.", lstrlenW(L"office-AppPrivilege.")))
+    {
+        *value = 0;
+        return TRUE;
+    }
+    return FALSE;
+}
+
 HRESULT WINAPI SLGetLicensingStatusInformation(HSLC handle, const SLID *app, const SLID *product,
                                                LPCWSTR name, UINT *count, SL_LICENSING_STATUS **status)
 {
+    SL_LICENSING_STATUS *entry;
+    WCHAR env[4];
+
     FIXME("(%p %p %p %s %p %p) stub\n", handle, app, product, debugstr_w(name), count, status );
 
-    return SL_E_RIGHT_NOT_CONSUMED;
+    if (!handle || name || !count || !status)
+        return E_INVALIDARG;
+
+    entry = LocalAlloc(LPTR, sizeof(*entry));
+    if (!entry)
+        return E_OUTOFMEMORY;
+
+    if (product)
+        entry->SkuId = *product;
+    else if (app)
+        entry->SkuId = *app;
+    else if (has_consumed_right)
+        entry->SkuId = last_consumed_right;
+    else
+    {
+        LocalFree(entry);
+        return SL_E_RIGHT_NOT_CONSUMED;
+    }
+    if (GetEnvironmentVariableW(L"OFFICE_SPP_LICENSED_STATUS", env, ARRAY_SIZE(env)))
+    {
+        entry->eStatus = SL_LICENSING_STATUS_LICENSED;
+        entry->dwGraceTime = 0;
+        entry->dwTotalGraceDays = 0;
+        FIXME("returning diagnostic licensed status.\n");
+    }
+    else
+    {
+        entry->eStatus = SL_LICENSING_STATUS_IN_GRACE_PERIOD;
+        entry->dwGraceTime = 30 * 24 * 60;
+        entry->dwTotalGraceDays = 30;
+    }
+    entry->hrReason = S_OK;
+
+    *count = 1;
+    *status = entry;
+    return S_OK;
+}
