 HRESULT WINAPI SLGetLicensingStatusInformation(HSLC handle, const SLID *app, const SLID *product,
                                                LPCWSTR name, UINT *count, SL_LICENSING_STATUS **status)
 {
+    SL_LICENSING_STATUS *entry;
+
     FIXME("(%p %p %p %s %p %p) stub\n", handle, app, product, debugstr_w(name), count, status );
 
-    return SL_E_RIGHT_NOT_CONSUMED;
+    if (!handle || name || !count || !status)
+        return E_INVALIDARG;
+
+    entry = LocalAlloc(LPTR, sizeof(*entry));
+    if (!entry)
+        return E_OUTOFMEMORY;
+
+    if (product)
+        entry->SkuId = *product;
+    else if (app)
+        entry->SkuId = *app;
+    entry->eStatus = SL_LICENSING_STATUS_IN_GRACE_PERIOD;
+    entry->dwGraceTime = 30 * 24 * 60;
+    entry->dwTotalGraceDays = 30;
+    entry->hrReason = S_OK;
+
+    *count = 1;
+    *status = entry;
+    return S_OK;
+}
+
+HRESULT WINAPI SLGetSLIDList(HSLC handle, UINT query_type, const SLID *query,
+                             UINT return_type, UINT *count, SLID **data)
+{
+    FIXME("(%p %u %s %u %p %p) stub\n", handle, query_type, wine_dbgstr_guid(query),
+          return_type, count, data);
+
+    if (!count || !data)
+        return E_INVALIDARG;
+
+    *count = 0;
+    *data = NULL;
+    return S_OK;
+}
+
+HRESULT WINAPI SLInstallLicense(HSLC handle, UINT size, const BYTE *data, SLID *file)
+{
+    FIXME("(%p %u %p %p) stub\n", handle, size, data, file);
+
+    if (!handle || !size || !data || !file)
+        return E_INVALIDARG;
+
+    memset(file, 0, sizeof(*file));
+    return S_OK;
+}
+
+HRESULT WINAPI SLSetAuthenticationData(HSLC handle, UINT size, const BYTE *data)
